# Compiled binaries — anchored to repo root so it doesn't shadow
# cmd/real-esrgan-serve/ (the package source dir, same name).
/real-esrgan-serve
bin/

# Output files / directories
*_out/
*_out.*

# ONNX / TensorRT built engine files (`*.trt` was an early extension
# for TRT engines; the rebuild standardised on `*.engine`. Kept the
# pattern but anchored to a leading character class so it doesn't
# accidentally match `Dockerfile.trt`.)
*.onnx
*.engine
[a-z]*.trt

# remote_build.py's working-tree tarball staging area. Cleaned up on
# successful runs but leftover when create_pod sys.exits early on
# supply-constrained capacity. Excluding here so they don't bloat the
# next remote_build's tarball-of-the-tarballs.
build/dist/_remote-build-*.tar.gz

# Generated by `make prep-embed` — copy of models/MANIFEST.json so
# go:embed can reach it. Source of truth is models/MANIFEST.json.
internal/modelfetch/manifest.json

# Go workspace
go.work
go.work.sum

# OS Specific
.DS_Store
Thumbs.db

# Python bytecode
__pycache__/
*.pyc

# Local test scratch
imgs/

# Benchmark results (large, derived, regeneratable from runs)
build/bench/results.db
build/bench/results.db-shm
build/bench/results.db-wal

# PID files

# GitHub Release Scripts
gh/
